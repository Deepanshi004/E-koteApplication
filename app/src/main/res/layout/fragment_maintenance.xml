<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/maintenance"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    tools:context="ui.maintenance.maintenanceFragment">


    <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginTop="70dp">

            <!-- Title -->
            <TextView
                android:id="@+id/gunMaintenance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Gun Maintenance"
                android:textSize="40sp"
                android:textColor="@color/green_200"
                android:textStyle="bold"
                android:layout_gravity="center" />

            <!-- Gun ID -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingTop="16dp">

                <TextView
                    android:id="@+id/gunIdmaintenance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Gun ID:"
                    android:textSize="20dp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/gunId"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="2"
                    android:textSize="20dp"
                    android:hint="Enter ID" />
            </LinearLayout>

            <!-- Next Maintenance Date -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingTop="8dp">

                <TextView
                    android:id="@+id/nextmaintenancedate2"
                    android:layout_width="56dp"
                    android:layout_height="104dp"
                    android:layout_weight="1"
                    android:text="Next Maintenance Date:"
                    android:textSize="20dp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/nextMaintenanceDate"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="2"
                    android:hint="DD-MM-YYYY"
                    android:textSize="20dp"
                    android:layout_marginTop="30dp"
                    android:inputType="date" />
            </LinearLayout>

        <!-- Save Button -->
            <Button
            android:id="@+id/saveMaintenanceDateButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Save Maintenance Date"
            android:layout_marginTop="16dp" />

            <!-- View Maintenance History Button -->
            <Button
                android:id="@+id/viewMaintenanceHistoryButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="View Maintenance History"
                android:layout_marginTop="16dp" />


        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerViewmaintenance"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"/>


        </LinearLayout>
</ScrollView>
