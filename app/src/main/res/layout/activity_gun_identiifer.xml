<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- EditText for entering the unique identifier -->
        <EditText
            android:id="@+id/editTextGunId"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Enter Gun Id"
            android:inputType="text"
            android:layout_marginBottom="16dp"/>

        <!-- Button to submit the unique identifier -->
        <Button
            android:id="@+id/buttonSubmit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Submit"
            android:layout_gravity="center"/>

        <!-- TextView to display the entered unique identifier -->

        <!-- RecyclerView for displaying gun IDs -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerViewGunIds"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"/>

    </LinearLayout>
</ScrollView>
